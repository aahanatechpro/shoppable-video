DirectoryIndex disabled
RewriteEngine On

# Serve the PHP proxy entrypoint for the root path only.
RewriteRule ^$ index.php [L]

# Proxy Shopify app routes and app APIs directly to the Node app.
# Your production Node app runs on port 3002 via SHOPPABLE_VIDEO.
RewriteRule ^((?:app|api|auth|webhooks)(?:\.data|(?:/.*)?)|__manifest)$ http://127.0.0.1:3002/$1 [P,L]

# Allow direct access to existing files and directories.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Rewrite static files to public/ when they don't exist at the project root.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -f
RewriteRule ^(.+)$ public/$1 [L]
